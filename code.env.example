# CCTBv4 — Variáveis de ambiente
# Copie este arquivo para code.env e preencha com suas credenciais reais.
# NUNCA commite o code.env com valores reais.

# ── OKX API (obrigatório para dados históricos e trading) ────────────────────
OKX_API_KEY=sua_api_key_aqui
OKX_SECRET_KEY=sua_secret_key_aqui
OKX_PASSPHRASE=sua_passphrase_aqui

# ── Oracle Server (opcional — só para deploy remoto) ────────────────────────
ORACLE_HOST=http://seu_servidor/
ORACLE_USER=ubuntu
ORACLE_SSH_KEY=/caminho/para/sua_chave.key

# ── Dashboard ────────────────────────────────────────────────────────────────
RESET_TOKEN=reset2026
